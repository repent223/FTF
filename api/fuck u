if getgenv().Premium then return end

getgenv().GodTable =  {
    WalkSpeed = false,
    WalkSpeedValue = 15,
}

local PLAYERS = game:GetService("Players")
local LP = PLAYERS.LocalPlayer

if getgenv().GodTable.WalkSpeed then
    local char = LP.Character 
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.WalkSpeed = getgenv().GodTable.WalkSpeedValue
    end
end
